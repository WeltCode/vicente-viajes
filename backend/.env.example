# ===========================================
# VICENTE VIAJES - Variables de Entorno
# ===========================================
# Copia este archivo como .env.production o .env.staging
# y configura tus valores reales
# ===========================================

# ===========================================
# DJANGO CONFIGURATION
# ===========================================

# Clave secreta de Django (genera una nueva para producción)
DJANGO_SECRET_KEY=CAMBIA_ESTA_CLAVE_EN_PRODUCCION

# Modo debug (True para desarrollo, False para producción)
DJANGO_DEBUG=False

# Hosts permitidos (separados por coma)
DJANGO_ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com,localhost,127.0.0.1

# ===========================================
# CORS CONFIGURATION
# ===========================================

# Orígenes permitidos para CORS (frontend)
DJANGO_CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com,http://localhost:5173

# Orígenes confiables para CSRF
DJANGO_CSRF_TRUSTED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# URL de base de datos
# Desarrollo local: deja vacío y se usa backend/db.sqlite3
# Producción/Staging: usa una URL PostgreSQL distinta por entorno
DATABASE_URL=

# Máxima edad de conexiones a BD (segundos)
DATABASE_CONN_MAX_AGE=600

# ===========================================
# EMAIL CONFIGURATION
# ===========================================

# Configuración SMTP para envío de emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=info@vicenteviajes.com
EMAIL_HOST_PASSWORD=TU_APP_PASSWORD_AQUI
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=20

# Email del remitente por defecto
DEFAULT_FROM_EMAIL=Vicente Viajes <info@vicenteviajes.com>

# Email donde llegan los mensajes de contacto
CONTACT_RECIPIENT_EMAIL=info@vicenteviajes.com

# URL del logo para emails
CONTACT_EMAIL_LOGO_URL=https://tu-dominio.com/logo-email.png

# ===========================================
# EXTERNAL SERVICES (Próximas integraciones)
# ===========================================

# Cloudinary (para imágenes - próximamente)
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# QueryBridge (motor de vuelos - próximamente)
QUERYBRIDGE_API_KEY=tu-api-key-querybridge
QUERYBRIDGE_BASE_URL=https://api.querybridge.com

# ===========================================
# DEVELOPMENT NOTES
# ===========================================
#
# 1. Para desarrollo local (.env.staging):
#    - Copia este archivo como .env.staging
#    - Deja DATABASE_URL vacío (usa SQLite)
#    - Configura EMAIL_HOST vacío para usar console backend
#
# 2. Para producción (.env.production):
#    - Copia este archivo como .env.production
#    - Configura DATABASE_URL con PostgreSQL
#    - Genera una nueva DJANGO_SECRET_KEY
#    - Configura EMAIL_HOST_USER y EMAIL_HOST_PASSWORD
#
# 3. Nunca commits archivos .env reales al repositorio
#    - Usa .env.example como template
#    - El .gitignore protege tus secrets
